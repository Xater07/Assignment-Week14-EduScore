<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Toolbar -->
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/primary"
                app:title="Academic Terms"
                app:titleTextColor="@color/white"
                app:navigationIcon="@android:drawable/ic_menu_sort_by_size"
                app:navigationIconTint="@color/white"/>

            <!-- Optional Help info header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Configures academic periods. An academic term is marked active if today's date falls within its range."
                android:textColor="@color/grey_dark"
                android:textSize="12sp"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"/>

            <!-- List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_academic_terms"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingBottom="80dp"
                android:clipToPadding="false"/>
        </LinearLayout>

        <!-- Dynamic Admin floating action button to add term -->
        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fab_add_term"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:layout_margin="24dp"
            android:text="New Term"
            android:textColor="@color/white"
            app:icon="@android:drawable/ic_input_add"
            app:iconTint="@color/white"
            android:backgroundTint="@color/accent"
            android:visibility="gone"/>

    </RelativeLayout>

    <!-- Drawer Navigation layout -->
    <include layout="@layout/nav_drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
