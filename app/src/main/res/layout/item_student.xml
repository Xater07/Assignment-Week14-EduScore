<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="1dp"
    app:strokeColor="@color/grey_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Info column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_student_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Student Name"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tv_student_id_programme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S001 • Computer Science"
                android:textColor="@color/grey_dark"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"/>

            <!-- Colored chip manually drawn or using standard Chip component -->
            <TextView
                android:id="@+id/chip_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@color/success_active"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Admin action buttons -->
        <LinearLayout
            android:id="@+id/layout_admin_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Edit Button -->
            <ImageButton
                android:id="@+id/btn_edit_student"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_edit"
                android:tint="@color/accent"
                android:layout_marginEnd="8dp"
                android:contentDescription="Edit Student" />

            <!-- Delete Button -->
            <ImageButton
                android:id="@+id/btn_delete_student"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_delete"
                android:tint="@color/red"
                android:contentDescription="Delete Student" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
