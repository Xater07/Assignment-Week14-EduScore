<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="1dp"
    app:strokeColor="@color/grey_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Course details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_course_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Course Name"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tv_course_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="C001"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_credit_hours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Credits: 3 hrs"
                    android:textColor="@color/grey_dark"
                    android:textSize="13sp"
                    android:layout_marginEnd="16dp"/>

                <!-- Badge for enrolled students -->
                <TextView
                    android:id="@+id/badge_enrolled_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4 Enrolled"
                    android:textSize="11sp"
                    android:textColor="@color/white"
                    android:background="@color/accent"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:gravity="center"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Admin buttons -->
        <LinearLayout
            android:id="@+id/layout_admin_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Edit Button -->
            <ImageButton
                android:id="@+id/btn_edit_course"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_edit"
                android:tint="@color/accent"
                android:layout_marginEnd="8dp"
                android:contentDescription="Edit Course" />

            <!-- Delete Button -->
            <ImageButton
                android:id="@+id/btn_delete_course"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_delete"
                android:tint="@color/red"
                android:contentDescription="Delete Course" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
