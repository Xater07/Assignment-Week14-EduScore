<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="1dp"
    app:strokeColor="@color/grey_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Term Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_term_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Semester 1 2025/2026"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tv_term_id_dates"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="T001 • 2025-01-01 to 2025-06-30"
                android:textColor="@color/grey_dark"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"/>

            <!-- Status Chip -->
            <TextView
                android:id="@+id/chip_term_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@color/success_active"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Admin buttons -->
        <LinearLayout
            android:id="@+id/layout_admin_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Edit Button -->
            <ImageButton
                android:id="@+id/btn_edit_term"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_edit"
                android:tint="@color/accent"
                android:layout_marginEnd="8dp"
                android:contentDescription="Edit Term" />

            <!-- Delete Button -->
            <ImageButton
                android:id="@+id/btn_delete_term"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_delete"
                android:tint="@color/red"
                android:contentDescription="Delete Term" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
