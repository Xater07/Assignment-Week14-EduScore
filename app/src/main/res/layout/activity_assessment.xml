<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Toolbar -->
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/primary"
                app:title="Assessments"
                app:titleTextColor="@color/white"
                app:navigationIcon="@android:drawable/ic_menu_sort_by_size"
                app:navigationIconTint="@color/white"/>

            <!-- Filter Label & Selector -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@color/white"
                android:elevation="1dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Course View"
                    android:textColor="@color/grey_dark"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <!-- Spinner with border styling -->
                <Spinner
                    android:id="@+id/spinner_courses_filter"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@android:drawable/btn_dropdown"
                    android:spinnerMode="dropdown"/>
            </LinearLayout>

            <!-- Running total stats banner -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_weightage_standing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/grey_light"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/iv_weightage_status_icon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/stat_sys_warning"
                        android:layout_marginEnd="12dp"
                        android:tint="@color/red"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_total_weightage_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Weightage: 0%"
                            android:textColor="@color/black"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tv_total_weightage_subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Weightage must sum up to exactly 100%"
                            android:textColor="@color/grey_dark"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Items -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_assessments"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingBottom="80dp"
                android:clipToPadding="false"/>
        </LinearLayout>

        <!-- Lecturer FAB to add assessment -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_add_assessment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:layout_margin="24dp"
            android:backgroundTint="@color/accent"
            android:src="@android:drawable/ic_input_add"
            app:tint="@color/white"
            android:tint="@color/white"
            android:contentDescription="Add Assessment"
            android:visibility="gone"/>

    </RelativeLayout>

    <!-- Side Menu Drawer -->
    <include layout="@layout/nav_drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
